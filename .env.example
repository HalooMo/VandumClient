# Flask
SECRET_KEY=change-me-to-a-long-random-string
FLASK_ENV=production

# Database (PostgreSQL for production, sqlite fallback for dev)
DATABASE_URL=postgresql://dpunk:dpunk@db:5432/dpunk

# SpeechLab API (upstream inference server)
SPEECHLAB_BASE_URL=https://app.vandum.ru
SPEECHLAB_API_KEY=your-api-key-here
SPEECHLAB_MAX_UPLOAD_MB=500

# Mail (for email verification)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=Dpunk <noreply@dpunk.online>

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# App URL (for OAuth callbacks and email links)
# Local: http://localhost:5000  |  Production: https://app.vandum.ru
APP_URL=http://localhost:5000

# Admin bootstrap (first admin user)
ADMIN_EMAIL=admin@dpunk.online
ADMIN_PASSWORD=change-me
