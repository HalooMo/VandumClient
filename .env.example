# Flask
SECRET_KEY=change-me-to-a-long-random-string
FLASK_ENV=production

# Database (PostgreSQL for production, sqlite fallback for dev)
DATABASE_URL=postgresql://vandum:vandum@db:5432/vandum

# SpeechLab API
SPEECHLAB_BASE_URL=https://vandum.ru
SPEECHLAB_API_KEY=your-api-key-here
SPEECHLAB_MAX_UPLOAD_MB=500

# Mail (for email verification)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=Vandum <noreply@vandum.ru>

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# App URL (for OAuth callbacks and email links)
# Local: http://localhost:5000  |  Production: https://your-domain
APP_URL=http://localhost:5000

# Admin bootstrap (first admin user)
ADMIN_EMAIL=admin@vandum.ru
ADMIN_PASSWORD=change-me
